{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "lib": ["ES2023"],
    "types": ["node"],
    "paths": {
      "@antares/shared": ["../../packages/shared/src/index.ts"],
      "@antares/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "src/ipc.ts",
    "src/main/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
